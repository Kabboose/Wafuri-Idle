{
  "name": "wafuri-idle",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "preinstall": "node ./scripts/check-node-version.mjs",
    "install:all": "npm install --workspaces",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:migrate": "npm run prisma:migrate --workspace server",
    "lint": "eslint server/src client/src",
    "dev": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace server && npm run build --workspace client"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.1"
  }
}
